# Required for real YNAB calls
YNAB_ACCESS_TOKEN=replace-with-server-side-ynab-personal-access-token

# Required unless DEV_AUTH_BYPASS=true on localhost/test
OWNER_PASSPHRASE=replace-with-a-long-high-entropy-owner-passphrase

# Public HTTPS origin for Claude web deployment, e.g. https://ynab-mcp.example.com
PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Local development only. Rejected in production and ignored for non-local requests.
DEV_AUTH_BYPASS=false

# Optional testing/development override
YNAB_API_BASE_URL=https://api.ynab.com/v1
